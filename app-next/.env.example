# Supabase — obtén estos valores en: supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Dominios de email permitidos para iniciar sesión (cuentas Zoho de Zivelo).
# Separados por coma. Vacío = sin restricción (solo para desarrollo local).
NEXT_PUBLIC_ALLOWED_EMAIL_DOMAINS=zivelo.mx

# Copia este archivo como .env.local y rellena con tus valores reales
# NUNCA commitees .env.local al repositorio
